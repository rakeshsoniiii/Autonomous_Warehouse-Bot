// ===================== MANUAL =====================

void handleDrive(){

  int l = server.hasArg("l")
          ? server.arg("l").toInt()
          : 0;

  int r = server.hasArg("r")
          ? server.arg("r").toInt()
          : 0;

  setMotors(l, r);

  showLCD(
    "MANUAL MODE",
    "RUNNING..."
  );

  server.send(
    200,
    "text/plain",
    "OK"
  );
}

