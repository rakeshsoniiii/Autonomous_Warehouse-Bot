#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

const char* ssid     = "Rak";
const char* password = "@1212@#1";

WebServer server(80);

LiquidCrystal_I2C lcd(0x27, 16, 2);


// ===================== PINS =====================

#define IN1 4
#define IN2 5
#define ENA 14

#define IN3 18
#define IN4 19
#define ENB 13

#define TRIG_PIN 26
#define ECHO_PIN 27


// ===================== MOTOR =====================

void setMotors(int l, int r) {

  // LEFT
  if (l >= 0) {

    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);

  } else {

    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);

    l = -l;
  }

  // RIGHT
  if (r >= 0) {

    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);

  } else {

    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);

    r = -r;
  }

  ledcWrite(0, constrain(l, 0, 255));
  ledcWrite(1, constrain(r, 0, 255));
}


// ===================== STOP =====================

void stopBot() {

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);

  ledcWrite(0, 0);
  ledcWrite(1, 0);
}


// ===================== DISTANCE =====================

long getDistance() {

  long duration;
  long distance;
  long total = 0;

  for(int i=0;i<5;i++){

    digitalWrite(TRIG_PIN, LOW);
    delayMicroseconds(2);

    digitalWrite(TRIG_PIN, HIGH);
    delayMicroseconds(10);

    digitalWrite(TRIG_PIN, LOW);

    duration = pulseIn(ECHO_PIN, HIGH, 30000);

    distance = duration * 0.034 / 2;

    total += distance;

    delay(10);
  }

  return total / 5;
}


// ===================== OBSTACLE =====================

bool obstacleAvoid() {

  long dist = getDistance();

  lcd.clear();

  lcd.setCursor(0,0);
  lcd.print("DIST:");

  lcd.print(dist);
  lcd.print("cm");

  // OBSTACLE DETECT
  if(dist > 0 && dist < 15){

    lcd.clear();
    lcd.print("OBSTACLE!");

    stopBot();
    delay(300);

    // BACK 1 SEC
    setMotors(-180,-180);
    delay(1000);

    stopBot();
    delay(300);

    // RIGHT SMALL TURN
    setMotors(170,-170);
    delay(500);

    stopBot();
    delay(300);

    lcd.clear();
    lcd.print("PATH CHANGED");

    return true;
  }

  return false;
}


// ===================== DISPLAY =====================

void loadingAnimation(String text){

  lcd.clear();

  lcd.setCursor(0,0);
  lcd.print(text);

  for(int i=0;i<16;i++){

    lcd.setCursor(i,1);

    lcd.print((char)255);

    delay(90);
  }
}


