// ================== SETUP ==================
void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.print("Booting Bot...");

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  ledcAttach(ENA, 1000, 8);
  ledcAttach(ENB, 1000, 8);

  stopBot();
  WiFi.begin(ssid, password);

  lcd.clear();
  lcd.print("Connecting WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println(WiFi.localIP());
  lcd.clear();
  lcd.print("IP:");
  lcd.print(WiFi.localIP());
  delay(2000);

  server.on("/", handleRoot);
  server.on("/drive", handleDrive);
  server.on("/stop", handleStop);
  server.on("/mission", handleMission);
  server.on("/status", handleStatus);
  server.begin();

  lcd.clear();
  lcd.print("IDLE @ HOME (3)");
}

// ================== LOOP ==================
void loop() {
  server.handleClient();
  
  // Obstacle detection runs only when bot is actively on a mission
  if (missionActive) {
    long dist = getDistance();
    
    // 12cm threshold covers high-speed momentum (detects by 10cm)
    if (dist > 1 && dist <= 12) { 
      delay(10); // Double check filter for sensor noise
      if (getDistance() <= 12) {
        executeSideDodge();
      }
    }
  }
}
