#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

const char* ssid     = "Rak";
const char* password = "@1212@#1";

WebServer server(80);
LiquidCrystal_I2C lcd(0x27, 16, 2);

// ================== MOTOR PINS ==================
#define IN1 4
#define IN2 5
#define ENA 14

#define IN3 18
#define IN4 19
#define ENB 13

// ================== ULTRASONIC PINS ==================
#define TRIG_PIN 26
#define ECHO_PIN 27

// ================== VARIABLES ==================
bool missionActive = false;
int targetID = 0;

// ================== MOTOR CONTROL ==================
void setMotors(int l, int r) {
  if (l >= 0) {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
  } else {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    l = -l; 
  }

  if (r >= 0) {
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
  } else {
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
    r = -r; 
  }

  ledcWrite(ENA, constrain(l, 0, 255));
  ledcWrite(ENB, constrain(r, 0, 255));
}

void stopBot() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
  ledcWrite(ENA, 0);
  ledcWrite(ENB, 0);
}

// ================== OBSTACLE AVOIDANCE ==================
long getDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  
  // Timeout 10ms (approx 1.7 meters max detection) to keep loop fast
  long duration = pulseIn(ECHO_PIN, HIGH, 10000); 
  if (duration == 0) return 400; // Safe if no echo
  
  return (duration * 0.0343) / 2;
}

void executeSideDodge() {
  lcd.clear();
  lcd.print("OBSTACLE DETECT!");
  lcd.setCursor(0, 1);
  lcd.print("DODGING SIDE...");

  stopBot();
  delay(100); // Brake

  // 1. Back up a little
  setMotors(-180, -180);
  delay(250);

  // 2. Spin Right 
  setMotors(255, -255);
  delay(350);

  // 3. Drive forward to clear obstacle side
  setMotors(200, 200);
  delay(500);

  // 4. Stop and let Camera re-calculate path
  stopBot();

  // Restore LCD
  lcd.clear();
  lcd.print("FETCH: ID ");
  lcd.print(targetID);
  lcd.setCursor(0, 1);
  lcd.print("RETURNING TO: 3");
}

// ================== ROUTES ==================
void handleDrive() {
  int l = server.arg("l").toInt();
  int r = server.arg("r").toInt();
  setMotors(l, r);
  server.send(200, "text/plain", "OK");
}

void handleStop() {
  stopBot();
  missionActive = false;
  targetID = 0;

  lcd.clear();
  lcd.print("IDLE @ HOME (3)");
  server.send(200, "text/plain", "STOPPED");
}

void handleMission() {
  if (server.hasArg("id")) {
    targetID = server.arg("id").toInt();
    missionActive = true;

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("FETCH: ID ");
    lcd.print(targetID);
    lcd.setCursor(0, 1);
    lcd.print("RETURNING TO: 3");

    server.send(200, "text/plain", "MISSION STARTED");
  }
}

void handleStatus() {
  String json = "{";
  json += "\"mission\":";
  json += missionActive ? "1" : "0";
  json += ",";
  json += "\"target\":";
  json += targetID;
  json += "}";
  server.send(200, "application/json", json);
}

