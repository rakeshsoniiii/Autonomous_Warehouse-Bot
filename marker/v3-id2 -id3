  server.send(200, "text/html", page);
}

// ================== SETUP ==================
void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.print("Booting Bot...");

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  ledcAttach(ENA, 1000, 8);
  ledcAttach(ENB, 1000, 8);

  stopBot();
  WiFi.begin(ssid, password);

  lcd.clear();
  lcd.print("Connecting WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println(WiFi.localIP());
  lcd.clear();
  lcd.print(WiFi.localIP());
  delay(2000);

  server.on("/", handleRoot);
  server.on("/drive", handleDrive);
  server.on("/stop", handleStop);
  server.on("/mission", handleMission);
  server.on("/status", handleStatus);
  server.begin();

  lcd.clear();
  lcd.print("READY / IDLE");
}

// ================== LOOP ==================
void loop() {
  server.handleClient();
  // No ultrasonic delays, loop runs ultra-fast now!
}
