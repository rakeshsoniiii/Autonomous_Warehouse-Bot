#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

const char* ssid     = "Rak";
const char* password = "@1212@#1";

WebServer server(80);
LiquidCrystal_I2C lcd(0x27, 16, 2);

// ================== MOTOR PINS ==================
#define IN1 4
#define IN2 5
#define ENA 14

#define IN3 18
#define IN4 19
#define ENB 13

// ================== VARIABLES ==================
bool missionActive = false;
int targetID = 0;

// ================== MOTOR CONTROL ==================
void setMotors(int l, int r) {
  if (l >= 0) {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
  } else {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    l = -l; // Make positive for PWM
  }

  if (r >= 0) {
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
  } else {
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
    r = -r; // Make positive for PWM
  }

  // Pure speed control
  ledcWrite(ENA, constrain(l, 0, 255));
  ledcWrite(ENB, constrain(r, 0, 255));
}

void stopBot() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
  ledcWrite(ENA, 0);
  ledcWrite(ENB, 0);
}

// ================== ROUTES ==================
void handleDrive() {
  int l = server.arg("l").toInt();
  int r = server.arg("r").toInt();
  setMotors(l, r);
  server.send(200, "text/plain", "OK");
}

void handleStop() {
  stopBot();
  missionActive = false;
  targetID = 0;

  lcd.clear();
  lcd.print("READY / IDLE");
  server.send(200, "text/plain", "STOPPED");
}

void handleMission() {
  if (server.hasArg("id")) {
    targetID = server.arg("id").toInt();
    missionActive = true;

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("PATH: 2 -> 3");
    lcd.setCursor(0, 1);
    lcd.print("SPEED: MAX");

    server.send(200, "text/plain", "MISSION STARTED");
  }
}

void handleStatus() {
  String json = "{";
  json += "\"mission\":";
  json += missionActive ? "1" : "0";
  json += ",";
  json += "\"target\":";
  json += targetID;
  json += "}";
  server.send(200, "application/json", json);
}

// ================== WEBPAGE ==================
void handleRoot() {
  String page = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
<title>Warehouse Bot Control</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
body{ font-family:Arial; text-align:center; background:#111; color:white; margin-top:40px; }
