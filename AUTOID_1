// ===================== SETUP =====================

void setup() {

  Serial.begin(115200);

  Wire.begin(21,22);

  lcd.init();
  lcd.backlight();

  showLCD(
    "WAREHOUSE BOT",
    "STARTING..."
  );

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);

  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  ledcAttach(ENA, 1000, 8);
  ledcAttach(ENB, 1000, 8);

  stopBot();

  // WIFI

  WiFi.begin(ssid, password);

  showLCD(
    "CONNECTING",
    "WIFI..."
  );

  while (WiFi.status() != WL_CONNECTED) {

    delay(500);

    Serial.print(".");
  }

  Serial.println("");

  Serial.println(WiFi.localIP());

  showLCD(
    "BOT IP",
    WiFi.localIP().toString()
  );

  delay(3000);

  // ROUTES

  server.on("/", handleHome);

  server.on("/drive", handleDrive);

  server.on("/id1", handleID1);

  server.on("/stop", handleStop);

  server.on("/return", handleReturn);

  server.begin();

  showLCD(
    "READY!",
    ""
  );
}

// ===================== LOOP =====================

void loop() {

  server.handleClient();
}
