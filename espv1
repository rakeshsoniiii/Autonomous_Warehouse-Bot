// ===================== PINS =====================

#define IN1 4
#define IN2 5
#define ENA 14

#define IN3 18
#define IN4 19
#define ENB 13

#define TRIG_PIN 26
#define ECHO_PIN 27

// ===================== DISPLAY =====================

String currentMessage = "READY!";

// ===================== LAST ID =====================

int lastID = 0;

// ===================== MOTOR =====================

void setMotors(int l, int r) {

  // LEFT MOTOR

  if (l >= 0) {

    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);

  } else {

    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);

    l = -l;
  }

  // RIGHT MOTOR

  if (r >= 0) {

    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);

  } else {

    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);

    r = -r;
  }

  ledcWrite(ENA, constrain(l, 0, 255));
  ledcWrite(ENB, constrain(r, 0, 255));
}

// ===================== LCD =====================

void showLCD(String line1, String line2 = "") {

  lcd.clear();

  lcd.setCursor(0,0);
  lcd.print(line1);

  lcd.setCursor(0,1);
  lcd.print(line2);

  currentMessage = line1;
}

// ===================== STOP =====================

void stopBot() {

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);

  ledcWrite(ENA, 0);
  ledcWrite(ENB, 0);
}

// ===================== DISTANCE =====================

long getDistance() {

  long duration;
  long distance;
  long total = 0;

  for(int i=0;i<5;i++){

    digitalWrite(TRIG_PIN, LOW);
    delayMicroseconds(2);

    digitalWrite(TRIG_PIN, HIGH);
    delayMicroseconds(10);

    digitalWrite(TRIG_PIN, LOW);

    duration = pulseIn(ECHO_PIN, HIGH, 30000);

    distance = duration * 0.034 / 2;

    total += distance;

    delay(10);
  }

  return total / 5;
}

// ===================== OBSTACLE =====================

bool obstacleAvoid() {

  long dist = getDistance();

  if(dist > 0 && dist < 15){

    showLCD(
      "OBSTACLE!",
      "AVOIDING..."
    );

    stopBot();
    delay(300);

    // BACK

    setMotors(-180,-180);
    delay(1000);

    stopBot();
    delay(300);

    // RIGHT TURN

    setMotors(170,-170);
    delay(500);

    stopBot();
    delay(300);

    return true;
  }

  return false;
}

// ===================== LOADING =====================

void loadingAnimation(String text){

  lcd.clear();

  lcd.setCursor(0,0);
  lcd.print(text);

  for(int i=0;i<16;i++){

    lcd.setCursor(i,1);

    lcd.print((char)255);

    delay(70);
  }
}

