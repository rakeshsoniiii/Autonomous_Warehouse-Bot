// ===================== HANDLERS =====================

void handleDrive(){

  int l = server.hasArg("l")
          ? server.arg("l").toInt()
          : 0;

  int r = server.hasArg("r")
          ? server.arg("r").toInt()
          : 0;

  setMotors(l, r);

  showLCD(
    "MANUAL MODE",
    "RUNNING..."
  );

  server.send(
    200,
    "text/plain",
    "OK"
  );
}

void handleStop(){

  stopBot();

  showLCD(
    "STOPPED",
    ""
  );

  server.send(
    200,
    "text/plain",
    "STOP"
  );
}

void handleDistance(){

  long dist = getDistance();

  String response =
  "{\"distance\":" + String(dist) + "}";

  server.send(
    200,
    "application/json",
    response
