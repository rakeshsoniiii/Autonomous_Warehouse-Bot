#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

const char* ssid     = "Rak";
const char* password = "@1212@#1";

WebServer server(80);

LiquidCrystal_I2C lcd(0x27, 16, 2);


// ===================== PINS =====================

#define IN1 4
#define IN2 5
#define ENA 14

#define IN3 18
#define IN4 19
#define ENB 13

#define TRIG_PIN 26
#define ECHO_PIN 27


// ===================== MOTOR =====================

void setMotors(int l, int r) {

  // LEFT
  if (l >= 0) {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
  } else {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    l = -l;
  }

  // RIGHT
  if (r >= 0) {
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
  } else {
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
    r = -r;
  }

  ledcWrite(0, constrain(l, 0, 255));
  ledcWrite(1, constrain(r, 0, 255));
}


// ===================== STOP =====================

void stopBot() {

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);

  ledcWrite(0, 0);
  ledcWrite(1, 0);
}


// ===================== DISTANCE =====================

long getDistance() {

  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);

  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH, 30000);

  long distance = duration * 0.034 / 2;

  return distance;
}


// ===================== OBSTACLE =====================

void obstacleAvoid() {

  long dist = getDistance();

  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Obstacle:");
  lcd.print(dist);

  if (dist < 15) {

    lcd.clear();
    lcd.print("BLOCKED!");

    stopBot();
    delay(400);

    // BACK
    setMotors(-170, -170);
    delay(600);

    // RIGHT TURN
    setMotors(170, -170);
    delay(700);

    stopBot();
    delay(300);

    lcd.clear();
    lcd.print("PATH CHANGED");
  }
}


// ===================== DISPLAY =====================

void loadingAnimation(String text){

  lcd.clear();

  lcd.setCursor(0,0);
  lcd.print(text);

  for(int i=0;i<16;i++){

    lcd.setCursor(i,1);
    lcd.print((char)255);

    delay(120);
  }
}


// ===================== ID1 =====================

void goID1(){

  loadingAnimation("GO TO ID 1");

  lcd.clear();
  lcd.print("LEFT TURN");

  // LEFT
  setMotors(-170,170);
  delay(700);

  stopBot();
  delay(300);

  obstacleAvoid();

  lcd.clear();
  lcd.print("FORWARD");

  // FORWARD
  setMotors(180,180);
  delay(2300);

  stopBot();
  delay(300);

  lcd.clear();
  lcd.print("RIGHT TURN");

  // RIGHT
  setMotors(170,-170);
  delay(700);

  stopBot();
  delay(300);

  lcd.clear();
  lcd.print("ARRIVED ID1");

  stopBot();
}


// ===================== ID2 =====================

void goID2(){

  loadingAnimation("GO TO ID 2");

  obstacleAvoid();

  lcd.clear();
  lcd.print("FORWARD");

  setMotors(180,180);
  delay(3200);

  stopBot();

  lcd.clear();
  lcd.print("ARRIVED ID2");
}


// ===================== ID3 =====================

void goID3(){

  loadingAnimation("GO TO ID 3");

  lcd.clear();
  lcd.print("RIGHT TURN");

  // RIGHT
  setMotors(170,-170);
  delay(700);

  stopBot();
  delay(300);

  obstacleAvoid();

  lcd.clear();
  lcd.print("FORWARD");

  // FORWARD
  setMotors(180,180);
  delay(2300);

  stopBot();
  delay(300);

  lcd.clear();
  lcd.print("LEFT TURN");

  // LEFT
  setMotors(-170,170);
  delay(700);

  stopBot();
  delay(300);

  lcd.clear();
  lcd.print("ARRIVED ID3");
}


// ===================== HANDLERS =====================

void handleDrive(){

  int l = server.hasArg("l") ? server.arg("l").toInt() : 0;

  int r = server.hasArg("r") ? server.arg("r").toInt() : 0;

  setMotors(l, r);

  lcd.clear();

  lcd.setCursor(0,0);
  lcd.print("MANUAL MODE");

  lcd.setCursor(0,1);
  lcd.print("L:");
  lcd.print(l);

  lcd.print(" R:");
  lcd.print(r);

  server.send(200, "text/plain", "OK");
}


void handleStop(){

  stopBot();

  lcd.clear();
  lcd.print("STOPPED");

  server.send(200, "text/plain", "STOP");
}


void handleDistance(){

  long dist = getDistance();

  String response =
  "{\"distance\":" + String(dist) + "}";

  server.send(200, "application/json", response);
}


void handleID1(){

  goID1();

  server.send(200,"text/plain","ID1 DONE");
}

void handleID2(){

  goID2();

  server.send(200,"text/plain","ID2 DONE");
}

void handleID3(){

  goID3();

  server.send(200,"text/plain","ID3 DONE");
}


// ===================== SETUP =====================

void setup() {

  Serial.begin(115200);

  Wire.begin(21,22);

  lcd.init();
  lcd.backlight();

  lcd.clear();
  lcd.print("WAREHOUSE BOT");

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);

  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  ledcSetup(0, 1000, 8);
  ledcSetup(1, 1000, 8);

  ledcAttachPin(ENA, 0);
  ledcAttachPin(ENB, 1);

  stopBot();

  // WIFI
  WiFi.begin(ssid, password);

  lcd.clear();
  lcd.print("CONNECT WIFI");

  while (WiFi.status() != WL_CONNECTED) {

    delay(500);

    Serial.print(".");
  }

  Serial.println("");
  Serial.println(WiFi.localIP());

  lcd.clear();
  lcd.print(WiFi.localIP());

  delay(2000);

  // ROUTES
  server.on("/drive", handleDrive);

  server.on("/stop", handleStop);

  server.on("/distance", handleDistance);

  server.on("/id1", handleID1);

  server.on("/id2", handleID2);

  server.on("/id3", handleID3);

  server.begin();

  lcd.clear();
  lcd.print("READY!");
}


// ===================== LOOP =====================

void loop() {

  server.handleClient();
}
